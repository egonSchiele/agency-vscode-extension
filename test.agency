import node { fetch } from "node-fetch"

msg = input("> ")

type Category = "import_recipe" | "create_ingredient"

type Url = {
  url: string # website url
}

node node main() {
  msg = input("> ")
  category: Category = llm("determine if the user wants to import a recipe from a website or create a new ingredient based on this message: ${msg}")

  match(category) {
    "import_recipe" => return importRecipe()
    "create_ingredient" => return createIngredient()
  }
}

def importRecipe() {
  url: Url = llm("extract the url from this message: ${msg}")
  html: string = fetch(url.url)
  recipe: string = llm("extract the recipe from this html: ${html}")

  print(recipe)
}

def createIngredient() {
  print("tbd")
}