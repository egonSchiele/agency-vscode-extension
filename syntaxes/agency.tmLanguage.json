{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Agency",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#function-definition"
    },
    {
      "include": "#type-definition"
    },
    {
      "include": "#backtick-strings"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#annotations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#inline-block"
    },
    {
      "include": "#function-call"
    },
    {
      "include": "#member-access"
    },
    {
      "include": "#type-annotation"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.agency",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.agency",
          "match": "//.*$"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.agency",
          "begin": "(@)([a-zA-Z_][a-zA-Z0-9_]*)(\\()",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.annotation.agency"
            },
            "2": {
              "name": "entity.name.function.annotation.agency"
            },
            "3": {
              "name": "punctuation.definition.parameters.begin.agency"
            }
          },
          "end": "\\)",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.parameters.end.agency"
            }
          },
          "patterns": [
            {
              "include": "#expression"
            }
          ]
        },
        {
          "name": "meta.annotation.agency",
          "match": "(@)([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "punctuation.definition.annotation.agency"
            },
            "2": {
              "name": "entity.name.function.annotation.agency"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.agency",
          "match": "\\b(if|while|for|match|return|async|await|throws|try|catch|else|uses|import|from|tool|thread|subthread|safe|shared|handle|with|export|let|const|class|constructor|this|super|parallel|seq)\\b"
        },
        {
          "name": "storage.type.agency",
          "match": "\\b(def|type|node)\\b"
        },
        {
          "name": "support.function.builtin.agency",
          "match": "\\b(input|read|write|fetch|fetchJSON|fetchJson|print|llm|interrupt|approve|reject|fork)\\b"
        },
        {
          "name": "support.type.builtin.agency",
          "match": "\\b(string|number|boolean|null|undefined|void|any)\\b"
        },
        {
          "name": "keyword.operator.expression.agency",
          "match": "\\b(typeof|instanceof|in|new|delete|void)\\b"
        },
        {
          "name": "constant.language.agency",
          "match": "\\b(true|false|null|undefined)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.agency",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.octal.agency",
          "match": "\\b0[oO][0-7]+\\b"
        },
        {
          "name": "constant.numeric.binary.agency",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.decimal.agency",
          "match": "\\b[0-9]+\\.?[0-9]*([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.decimal.agency",
          "match": "\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.type.annotation.agency",
          "match": "::"
        },
        {
          "name": "keyword.operator.arrow.agency",
          "match": "=>"
        },
        {
          "name": "keyword.operator.pipe.agency",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.spread.agency",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.optional-chaining.agency",
          "match": "\\?\\."
        },
        {
          "name": "keyword.operator.comparison.agency",
          "match": "===|!=="
        },
        {
          "name": "keyword.operator.comparison.agency",
          "match": "==|!="
        },
        {
          "name": "keyword.operator.assignment.compound.agency",
          "match": ">>>=|<<=|>>=|\\*\\*=|&&=|\\|\\|=|\\?\\?="
        },
        {
          "name": "keyword.operator.assignment.compound.agency",
          "match": "\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^="
        },
        {
          "name": "keyword.operator.bitwise.shift.agency",
          "match": ">>>|<<|>>"
        },
        {
          "name": "keyword.operator.comparison.agency",
          "match": "<=|>="
        },
        {
          "name": "keyword.operator.comparison.agency",
          "match": "<|>"
        },
        {
          "name": "keyword.operator.arithmetic.agency",
          "match": "\\*\\*"
        },
        {
          "name": "keyword.operator.increment-decrement.agency",
          "match": "\\+\\+|--"
        },
        {
          "name": "keyword.operator.logical.agency",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.nullish-coalescing.agency",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.logical.agency",
          "match": "!"
        },
        {
          "name": "keyword.operator.bitwise.agency",
          "match": "~"
        },
        {
          "name": "keyword.operator.type.union.agency",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.bitwise.agency",
          "match": "&|\\^"
        },
        {
          "name": "keyword.operator.arithmetic.agency",
          "match": "\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.assignment.agency",
          "match": "="
        },
        {
          "name": "keyword.operator.ternary.agency",
          "match": "\\?"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.agency",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "meta.template.expression.agency",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.template-expression.begin.agency"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.template-expression.end.agency"
            }
          },
          "patterns": [
            {
              "include": "#expression"
            }
          ]
        },
        {
          "name": "constant.character.escape.agency",
          "match": "\\\\."
        }
      ]
    },
    "backtick-strings": {
      "name": "string.template.agency",
      "begin": "`",
      "end": "`",
      "patterns": [
        {
          "name": "meta.template.expression.agency",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.template-expression.begin.agency"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.template-expression.end.agency"
            }
          },
          "patterns": [
            {
              "include": "#expression"
            }
          ]
        },
        {
          "name": "constant.character.escape.agency",
          "match": "\\\\."
        }
      ]
    },
    "expression": {
      "patterns": [
        {
          "include": "#strings"
        },
        {
          "include": "#backtick-strings"
        },
        {
          "include": "#inline-block"
        },
        {
          "include": "#function-call"
        },
        {
          "include": "#member-access"
        },
        {
          "include": "#keywords"
        },
        {
          "include": "#numbers"
        },
        {
          "include": "#operators"
        },
        {
          "include": "#type-annotation"
        },
        {
          "include": "#variables"
        }
      ]
    },
    "function-definition": {
      "name": "meta.function.agency",
      "begin": "\\b(def)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "beginCaptures": {
        "1": {
          "name": "storage.type.function.agency"
        },
        "2": {
          "name": "entity.name.function.agency"
        }
      },
      "end": "\\)",
      "patterns": [
        {
          "include": "#expression"
        }
      ]
    },
    "type-definition": {
      "name": "meta.type.definition.agency",
      "begin": "\\b(type)\\s+([A-Z][a-zA-Z0-9_]*)\\s*(=)",
      "beginCaptures": {
        "1": {
          "name": "storage.type.agency"
        },
        "2": {
          "name": "entity.name.type.agency"
        },
        "3": {
          "name": "keyword.operator.assignment.agency"
        }
      },
      "end": "(?<=})|(?=;)|$",
      "patterns": [
        {
          "include": "#type-body"
        },
        {
          "include": "#strings"
        },
        {
          "include": "#operators"
        }
      ]
    },
    "type-body": {
      "patterns": [
        {
          "name": "meta.type.record.agency",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            {
              "name": "comment.line.hash.agency",
              "match": "#.*$"
            },
            {
              "name": "meta.field.agency",
              "match": "([a-zA-Z_][a-zA-Z0-9_]*)(\\?)?\\s*(:)",
              "captures": {
                "1": {
                  "name": "variable.other.property.agency"
                },
                "2": {
                  "name": "keyword.operator.optional.agency"
                },
                "3": {
                  "name": "punctuation.separator.colon.agency"
                }
              }
            },
            {
              "include": "#keywords"
            },
            {
              "include": "#operators"
            },
            {
              "name": "entity.name.type.agency",
              "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
            }
          ]
        }
      ]
    },
    "inline-block": {
      "patterns": [
        {
          "comment": "Inline block with parenthesized params: \\(x, y) -> expr",
          "name": "meta.inline-block.agency",
          "match": "(\\\\)(\\()([^)]*)(\\))\\s*(->)",
          "captures": {
            "1": {
              "name": "punctuation.definition.inline-block.agency"
            },
            "2": {
              "name": "punctuation.definition.parameters.begin.agency"
            },
            "3": {
              "name": "variable.parameter.agency"
            },
            "4": {
              "name": "punctuation.definition.parameters.end.agency"
            },
            "5": {
              "name": "keyword.operator.arrow.agency"
            }
          }
        },
        {
          "comment": "Inline block with single param: \\x -> expr",
          "name": "meta.inline-block.agency",
          "match": "(\\\\)([a-zA-Z_][a-zA-Z0-9_]*)\\s*(->)",
          "captures": {
            "1": {
              "name": "punctuation.definition.inline-block.agency"
            },
            "2": {
              "name": "variable.parameter.agency"
            },
            "3": {
              "name": "keyword.operator.arrow.agency"
            }
          }
        }
      ]
    },
    "function-call": {
      "name": "meta.function-call.agency",
      "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
      "captures": {
        "1": {
          "name": "entity.name.function.agency"
        },
        "2": {
          "name": "punctuation.definition.parameters.begin.agency"
        }
      }
    },
    "member-access": {
      "name": "meta.member.access.agency",
      "match": "([a-zA-Z_][a-zA-Z0-9_]*)(\\.)([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": {
          "name": "variable.other.object.agency"
        },
        "2": {
          "name": "punctuation.accessor.agency"
        },
        "3": {
          "name": "variable.other.property.agency"
        }
      }
    },
    "type-annotation": {
      "match": "(:)\\s*([A-Z][a-zA-Z0-9_]*)",
      "captures": {
        "1": {
          "name": "punctuation.separator.colon.agency"
        },
        "2": {
          "name": "entity.name.type.agency"
        }
      }
    },
    "variables": {
      "name": "variable.other.readwrite.agency",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  },
  "scopeName": "source.agency"
}