{
  "name": "adl-lang",
  "displayName": "adl-lang",
  "description": "Language support for the ADL language",
  "version": "0.0.2",
  "publisher": "adl",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "languages": [{
      "id": "adl",
      "aliases": ["ADL", "adl"],
      "extensions": [".adl"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "adl",
      "scopeName": "source.adl",
      "path": "./syntaxes/adl.tmLanguage.json"
    }]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.107.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  }
}
