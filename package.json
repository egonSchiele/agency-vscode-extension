{
  "name": "agency-lang",
  "displayName": "agency-lang",
  "description": "Language support for the Agency language",
  "version": "0.0.2",
  "publisher": "agency",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:agency"
  ],
  "contributes": {
    "languages": [
      {
        "id": "agency",
        "aliases": [
          "Agency",
          "agency"
        ],
        "extensions": [
          ".agency"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "Agency",
      "properties": {
        "agency.lsp.command": {
          "type": "string",
          "default": "pnpm run --silent agency",
          "description": "Command to run the Agency CLI. Examples: 'agency', '/usr/local/bin/agency', 'pnpm run --silent agency', 'npx agency'. The 'lsp' argument is appended automatically."
        },
        "agency.formatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically format Agency files on save."
        }
      }
    },
    "grammars": [
      {
        "language": "agency",
        "scopeName": "source.agency",
        "path": "./syntaxes/agency.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "agency": "agency"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.107.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "agency-lang": "^0.0.107",
    "vscode-languageclient": "^9.0.1"
  }
}
